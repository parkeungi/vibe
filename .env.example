# ───────────────────────────────────────────
# Supabase MCP (Claude Code 연동용)
# ───────────────────────────────────────────
SUPABASE_ACCESS_TOKEN=your_personal_access_token   # supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=your_project_ref              # https://[project-ref].supabase.co

# ───────────────────────────────────────────
# Supabase (Next.js 앱용)
# ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ───────────────────────────────────────────
# 결제 - 포트원 (Portone)
# ───────────────────────────────────────────
PORTONE_API_SECRET=your_portone_api_secret
PORTONE_STORE_ID=your_store_id

# ───────────────────────────────────────────
# 이메일 - Resend
# ───────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
